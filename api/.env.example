# App
RUST_ENV=development          # development | production
RUST_LOG=info
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:8073,http://127.0.0.1:8073

# Bootstrap Configuration (first-time setup)
# Set to false after initial admin is created
BOOTSTRAP_ENABLED=true

# Initial Admin Credentials (only used if no admin exists)
# IMPORTANT: Change these in production!
BOOTSTRAP_ADMIN_EMAIL=admin@quax.dev
BOOTSTRAP_ADMIN_PASSWORD=admin123        # Change this!
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_NAME=Administrator

# Database - FOR HOST (cargo run)
DATABASE_URL=postgres://quax:secret@localhost:5432/quax_db
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1

# Redis (Optional — leave empty or comment out to disable)
# REDIS_URL=redis://localhost:6379
# 
# Redis is used for:
# - Session blacklisting (logout/revoke token invalidation)
# - User profile caching
# - Distributed rate limiting
# 
# If not configured, these features will be disabled gracefully.

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY_SECS=3600     # 1 hour
JWT_REFRESH_EXPIRY_SECS=604800  # 7 days

# Cookie Configuration (optional - defaults based on RUST_ENV)
# COOKIE_SAMESITE=strict        # strict | lax | none. Default: strict (prod), lax (dev)
# COOKIE_SECURE=true            # true | false. Default: true (prod), false (dev)
# COOKIE_HTTPONLY=true          # true | false. Default: true
# 
# Scenarios:
# - Cross-port dev (8073->8080): lax (default dev)
# - Cross-subdomain: none + secure=true
# - Same origin: strict (most secure)

# Upload Configuration
STORAGE_DRIVER=local              # local | jdcloud_oss
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:8080/media
MAX_AVATAR_SIZE=2097152         # 2 MB in bytes
MAX_UPLOAD_SIZE=20971520        # 20 MB in bytes
#
# IMPORTANT: Change UPLOAD_BASE_URL for production!
# 
# If FE (Vercel) and BE (VPS) are separate:
#   UPLOAD_BASE_URL=https://api.yourdomain.com/media
#
# If using S3/R2/MinIO:
#   UPLOAD_BASE_URL=https://cdn.yourdomain.com
#
# JD Cloud OSS (S3-compatible)
# STORAGE_DRIVER=jdcloud_oss
# JD_OSS_ACCESS_KEY_ID=your-access-key-id
# JD_OSS_ACCESS_KEY_SECRET=your-access-key-secret
# JD_OSS_BUCKET=shanhuai-gc
# JD_OSS_ENDPOINT=https://s3.cn-east-2.jdcloud-oss.com
# JD_OSS_REGION=cn-east-2
# JD_OSS_PUBLIC_BASE_URL=https://shanhuai-gc.s3.cn-east-2.jdcloud-oss.com

# JDCloud OCR Configuration
# JD_OCR_API_KEY=your-jdcloud-ocr-api-key
# JD_OCR_IDCARD_ENDPOINT=https://model.jdcloud.com/v1/idcard

# Note: API Keys are managed via Admin Dashboard (/admin/api-keys)
# Not configured via environment variables for security & auditability
