{
  "description": "Local WeChat DevTools settings. Open this folder directly in WeChat DevTools, then build npm.",
  "projectname": "wx",
  "condition": {},
  "libVersion": "3.15.2",
  "setting": {
    "urlCheck": true,
    "coverView": true,
    "lazyloadPlaceholderEnable": false,
    "skylineRenderEnable": false,
    "preloadBackgroundData": false,
    "autoAudits": false,
