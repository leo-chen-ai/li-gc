.module-page {
  min-height: 100vh;
  padding: 96rpx 30rpx 180rpx;
  background:
    radial-gradient(circle at 18% 0%, rgba(217, 244, 239, 0.9) 0, rgba(217, 244, 239, 0) 230rpx),
    linear-gradient(180deg, #f4f8f8 0%, #edf3f5 100%);
}

.module-hero {
  position: relative;
  overflow: hidden;
  min-height: 286rpx;
  padding: 26rpx 26rpx 28rpx;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(42, 59, 78, 0.07);
}

.module-hero-bg {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.module-hero::after {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 255, 255, 0.86) 58%, rgba(255, 255, 255, 0.28) 100%);
  content: "";
}

.hero-topline,
.hero-title-row,
.metric-strip,
.toolbar-card,
.record-footer,
.record-actions,
.sheet-header,
.sheet-footer,
.field-label {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
}

.hero-topline,
.hero-title-row,
.toolbar-card,
.record-footer,
.sheet-header,
.sheet-footer {
  justify-content: space-between;
}

.back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 20rpx;
  color: #102427;
  font-size: 48rpx;
  font-weight: 400;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 12rpx 28rpx rgba(42, 59, 78, 0.06);
}

.hero-kicker {
  flex: 1;
  margin-left: 18rpx;
  color: #718086;
  font-size: 23rpx;
  font-weight: 600;
}

.hero-title-row {
  margin-top: 28rpx;
}

.hero-title {
  color: #17282b;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.08;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: #718086;
  font-size: 24rpx;
  line-height: 1.35;
}

.hero-count {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  color: #0a9875;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 18rpx 44rpx rgba(42, 59, 78, 0.07);
}

.hero-count text:first-child {
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1;
}

.hero-count text:last-child {
  margin-top: 6rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.metric-strip {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.module-tabs {
  width: 100%;
  margin-top: 28rpx;
  white-space: nowrap;
}

.module-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 62rpx;
  padding: 0 24rpx;
  margin-right: 14rpx;
  border: 1rpx solid rgba(209, 221, 225, 0.86);
  border-radius: 999rpx;
  color: #66757b;
  font-size: 24rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.76);
}

.module-tab.active {
  border-color: #0a9875;
  color: #ffffff;
  background: #0a9875;
}

.metric-item {
  min-width: 0;
  padding: 22rpx 12rpx;
  border-radius: 18rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 12rpx 32rpx rgba(42, 59, 78, 0.045);
}

.metric-value {
  color: #203033;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.1;
}

.metric-value.accent {
  color: #0a9875;
}

.metric-label {
  margin-top: 8rpx;
  color: #7c8a90;
  font-size: 20rpx;
  line-height: 1.2;
}

.toolbar-card {
  gap: 18rpx;
  margin-top: 28rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 16rpx 42rpx rgba(42, 59, 78, 0.055);
}

.search-box {
  display: flex;
  flex: 1;
  align-items: center;
  min-width: 0;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 17rpx;
  background: #f4f8f8;
}

.search-dot {
  width: 14rpx;
  height: 14rpx;
  margin-right: 14rpx;
  border: 4rpx solid #9aabae;
  border-radius: 999rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 68rpx;
  color: #243033;
  font-size: 25rpx;
}

.toolbar-button,
.primary-button,
.empty-button {
  color: #ffffff;
  font-weight: 800;
  text-align: center;
  background: #0a9875;
}

.toolbar-button {
  width: 118rpx;
  height: 72rpx;
  border-radius: 17rpx;
  font-size: 26rpx;
  line-height: 72rpx;
}

.filter-row {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-chip {
  flex: 0 0 auto;
  height: 56rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(209, 221, 225, 0.85);
  border-radius: 999rpx;
  color: #69777d;
  font-size: 23rpx;
  line-height: 54rpx;
  background: rgba(255, 255, 255, 0.74);
}

.filter-chip.active {
  border-color: #0a9875;
  color: #ffffff;
  background: #0a9875;
}

.record-list {
  margin-top: 22rpx;
}

.record-card {
  position: relative;
  padding: 26rpx 24rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.93);
  box-shadow: 0 16rpx 42rpx rgba(42, 59, 78, 0.055);
}

.record-card + .record-card {
  margin-top: 18rpx;
}

.record-main {
  min-width: 0;
  padding-right: 120rpx;
}

.record-title {
  overflow: hidden;
  color: #1f2d30;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-subtitle {
  overflow: hidden;
  margin-top: 8rpx;
  color: #7b888d;
  font-size: 23rpx;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-badge {
  position: absolute;
  top: 26rpx;
  right: 24rpx;
  min-width: 92rpx;
  height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #7c8790;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 46rpx;
  text-align: center;
  background: #eef3f5;
}

.status-badge.ok {
  color: #0a9875;
  background: #e4f5ef;
}

.status-badge.warn {
  color: #b17311;
  background: #fff4dc;
}

.status-badge.danger {
  color: #c94a3a;
  background: #ffe8e3;
}

.record-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.detail-cell {
  min-width: 0;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f6f9f9;
}

.detail-label {
  color: #93a0a5;
  font-size: 20rpx;
  line-height: 1.1;
}

.detail-value {
  overflow: hidden;
  margin-top: 8rpx;
  color: #2e3a3e;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-footer {
  gap: 12rpx;
  margin-top: 20rpx;
}

.record-note {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #879399;
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-actions {
  flex: 0 0 auto;
  gap: 20rpx;
}

.text-button {
  min-width: 96rpx;
  height: 58rpx;
  padding: 0 18rpx;
  border-radius: 15rpx;
  color: #0a9875;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 58rpx;
  text-align: center;
  background: #e6f5f1;
}

.text-button.danger {
  color: #d65a44;
  background: #fff0ec;
}

.empty-state {
  padding: 74rpx 36rpx;
  border-radius: 24rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.82);
}

.empty-title {
  color: #243033;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-copy {
  margin-top: 12rpx;
  color: #7f8c91;
  font-size: 23rpx;
}

.empty-button {
  width: 220rpx;
  height: 68rpx;
  margin: 28rpx auto 0;
  border-radius: 17rpx;
  font-size: 25rpx;
  line-height: 68rpx;
}

.form-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 40;
  background: rgba(16, 31, 35, 0.32);
}

.form-sheet {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 41;
  box-sizing: border-box;
  max-height: 86vh;
  padding: 14rpx 30rpx calc(24rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: #f7faf9;
  box-shadow: 0 -22rpx 70rpx rgba(16, 31, 35, 0.18);
  transform: translateY(110%);
  transition: transform 180ms ease;
}

.form-sheet.show {
  transform: translateY(0);
}

.sheet-handle {
  width: 76rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: #d5e0e3;
}

.sheet-title {
  color: #1f2d30;
  font-size: 32rpx;
  font-weight: 800;
}

.sheet-subtitle {
  margin-top: 7rpx;
  color: #7f8c91;
  font-size: 22rpx;
}

.sheet-close {
  width: 58rpx;
  height: 58rpx;
  border-radius: 999rpx;
  color: #748187;
  font-size: 42rpx;
  line-height: 54rpx;
  text-align: center;
  background: #edf3f4;
}

.form-scroll {
  max-height: 58vh;
  margin-top: 24rpx;
}

.form-field {
  margin-bottom: 20rpx;
}

.field-label {
  justify-content: flex-start;
  margin-bottom: 12rpx;
  color: #59666b;
  font-size: 23rpx;
  font-weight: 700;
}

.required {
  margin-left: 4rpx;
  color: #d65a44;
}

.native-field,
.select-value,
.native-textarea {
  width: 100%;
  border: 1rpx solid #dce6e8;
  border-radius: 16rpx;
  color: #233033;
  font-size: 26rpx;
  background: #ffffff;
}

.native-field,
.select-value {
  height: 76rpx;
  padding: 0 22rpx;
  line-height: 74rpx;
}

.native-textarea {
  min-height: 150rpx;
  padding: 20rpx 22rpx;
  line-height: 1.45;
}

.placeholder,
.muted-placeholder {
  color: #a4afb4;
}

.sheet-footer {
  gap: 18rpx;
  padding-top: 16rpx;
}

.ghost-button,
.primary-button {
  flex: 1;
  height: 78rpx;
  border-radius: 18rpx;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 78rpx;
  text-align: center;
}

.ghost-button {
  color: #59666b;
  background: #eaf1f2;
}
