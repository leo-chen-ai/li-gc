.attendance-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 88rpx 24rpx calc(36rpx + env(safe-area-inset-bottom));
  background: #eef3f5;
}

.page-top {
  display: grid;
  grid-template-columns: 80rpx 1fr 80rpx;
  align-items: center;
  min-height: 70rpx;
}

.back-button {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  color: #14282b;
  font-size: 50rpx;
  line-height: 54rpx;
  text-align: center;
}

.page-title {
  color: #18282b;
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
}

.project-strip {
  position: relative;
  overflow: hidden;
  margin-top: 24rpx;
  padding: 28rpx 26rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(42, 59, 78, 0.052);
}

.project-bg {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.62;
}

.project-label,
.project-name {
  position: relative;
  z-index: 1;
}

.project-label {
  color: #6c7b80;
  font-size: 23rpx;
  font-weight: 700;
}

.project-name {
  margin-top: 8rpx;
  color: #243236;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.38;
}

.stats-card,
.filter-card,
.tab-row,
.attendance-worker {
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 36rpx rgba(42, 59, 78, 0.052);
}

.stats-card {
  margin-top: 20rpx;
  padding: 28rpx 20rpx 26rpx;
}

.month-title {
  color: #1f2d30;
  font-size: 34rpx;
  font-weight: 800;
  text-align: center;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  margin-top: 24rpx;
  text-align: center;
}

.stat-value {
  color: #263438;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.1;
}

.stat-value.present {
  color: #0a9875;
}

.stat-value.absent {
  color: #d84b72;
}

.stat-value.rate {
  color: #0b6fbd;
}

.stat-label {
  margin-top: 12rpx;
  color: #8a989d;
  font-size: 23rpx;
}

.filter-card {
  margin-top: 20rpx;
  padding: 18rpx;
}

.filter-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.filter-pill {
  height: 72rpx;
  border-radius: 18rpx;
  color: #263438;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
  text-align: center;
  background: #f4f7f8;
}

.search-row {
  display: grid;
  grid-template-columns: 1fr 112rpx 104rpx;
  gap: 14rpx;
  margin-top: 16rpx;
}

.search-input {
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  color: #223034;
  font-size: 26rpx;
  background: #f4f7f8;
}

.search-button,
.reset-button {
  height: 72rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
  text-align: center;
}

.search-button {
  color: #ffffff;
  background: #0a9875;
}

.reset-button {
  color: #68777d;
  background: #eef2f3;
}

.attendance-body {
  display: grid;
  grid-template-columns: 190rpx 1fr;
  gap: 18rpx;
  margin-top: 20rpx;
}

.date-rail {
  height: 880rpx;
  border-radius: 20rpx;
  background: #f7fafb;
}

.date-item {
  position: relative;
  height: 106rpx;
  color: #526166;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 106rpx;
  text-align: center;
  background: #f7fafb;
}

.date-item text {
  color: #d64b70;
}

.date-item.active {
  color: #17282b;
  background: #ffffff;
}

.date-item.active::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 8rpx;
  background: #0a9875;
  content: "";
}

.attendance-main {
  min-width: 0;
}

.tab-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  padding: 10rpx;
}

.tab-item {
  height: 72rpx;
  border-radius: 18rpx;
  color: #263438;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
  text-align: center;
}

.tab-item.active {
  color: #0a9875;
  background: #e8f6f2;
}

.worker-scroll {
  height: 780rpx;
  margin-top: 18rpx;
}

.attendance-worker {
  display: grid;
  grid-template-columns: 96rpx 1fr;
  gap: 20rpx;
  padding: 24rpx 20rpx;
}

.attendance-worker + .attendance-worker {
  margin-top: 18rpx;
}

.worker-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: #e6f1ee;
}

.worker-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.worker-name {
  color: #1f2d30;
  font-size: 31rpx;
  font-weight: 800;
}

.phone-action {
  color: #0a9875;
  font-size: 23rpx;
  font-weight: 800;
}

.worker-meta,
.worker-phone {
  margin-top: 9rpx;
  color: #7b888d;
  font-size: 24rpx;
}

.time-row {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.time-pill {
  flex: 1;
  min-width: 0;
  height: 54rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 54rpx;
  text-align: center;
}

.time-pill.in {
  color: #0a9875;
  background: #e4f7f1;
}

.time-pill.out {
  color: #d84b72;
  background: #fdeaf0;
}

.absent-note {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  color: #b07613;
  font-size: 23rpx;
  background: #fff5df;
}

.empty-state {
  padding: 80rpx 0;
  color: #7b888d;
  font-size: 25rpx;
  text-align: center;
}

.muted-placeholder {
  color: #a2adb1;
}
