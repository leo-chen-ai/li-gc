.profile-page {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  background: #f3f8f7;
}

.profile-bg-image,
.profile-bg-tint,
.profile-top-visual {
  position: fixed;
  top: 0;
  right: 0;
  left: 0;
  pointer-events: none;
}

.profile-bg-image {
  z-index: 0;
  width: 100%;
  height: 100vh;
  opacity: 0.92;
  transform: scale(1.04);
  animation: bgDrift 8s ease-in-out infinite alternate;
}

.profile-bg-tint {
  bottom: 0;
  z-index: 1;
  background:
    linear-gradient(180deg, rgba(248, 252, 251, 0.32) 0%, rgba(243, 248, 247, 0.72) 48%, #f3f8f7 100%),
    radial-gradient(circle at 24% 12%, rgba(10, 152, 117, 0.08), rgba(10, 152, 117, 0) 240rpx);
}

.profile-top-visual {
  z-index: 1;
  overflow: hidden;
  height: 610rpx;
}

.profile-top-visual::after {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background:
    linear-gradient(180deg, rgba(243, 248, 247, 0.12) 0%, rgba(243, 248, 247, 0.42) 56%, #f3f8f7 100%),
    linear-gradient(90deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.58) 42%, rgba(255, 255, 255, 0.16) 100%);
  content: "";
}

.profile-top-visual-image {
  position: absolute;
  top: 64rpx;
  right: -190rpx;
  width: 760rpx;
  height: 520rpx;
  opacity: 0.58;
  animation: visualFloat 8s ease-in-out infinite alternate;
  transform-origin: center;
}

.profile-content {
  position: relative;
  z-index: 2;
  min-height: 100vh;
  padding: 112rpx 30rpx calc(196rpx + constant(safe-area-inset-bottom));
  padding: 112rpx 30rpx calc(196rpx + env(safe-area-inset-bottom));
}

.profile-header,
.account-hero,
.phone-row,
.contact-card-content,
.bottom-nav,
.nav-item {
  display: flex;
  align-items: center;
}

.profile-header,
.phone-row,
.contact-card-content {
  justify-content: space-between;
}

.profile-header {
  animation: sectionEnter 360ms ease both;
}

.profile-title {
  color: #1b292c;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.1;
}

.profile-subtitle {
  margin-top: 8rpx;
  color: #7a878c;
  font-size: 22rpx;
}

.account-hero {
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  min-height: 178rpx;
  margin-top: 54rpx;
  padding: 30rpx 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.58);
  box-shadow: 0 18rpx 46rpx rgba(15, 107, 93, 0.08);
  animation: sectionEnter 420ms 60ms ease both;
}

.account-hero::after {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.7) 0%, rgba(255, 255, 255, 0.36) 100%);
  content: "";
  pointer-events: none;
}

.avatar-ring {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
  width: 128rpx;
  height: 128rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 18rpx 48rpx rgba(15, 107, 93, 0.12);
  animation: avatarFloat 3.6s ease-in-out infinite;
}

.avatar-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 58rpx;
  font-weight: 800;
  line-height: 1;
  background: linear-gradient(180deg, #12a27f 0%, #0f6b5d 100%);
}

.account-main {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  margin-left: 28rpx;
}

.user-name {
  overflow: hidden;
  color: #203033;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.12;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-account {
  overflow: hidden;
  margin-top: 10rpx;
  color: #6f7d83;
  font-size: 25rpx;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.phone-row {
  width: 282rpx;
  margin-top: 18rpx;
  color: #8a969b;
  font-size: 23rpx;
  font-weight: 700;
}

.phone-number {
  color: #0a9875;
  font-weight: 800;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
  margin-top: 30rpx;
  animation: sectionEnter 430ms 120ms ease both;
}

.info-card {
  min-height: 178rpx;
  padding: 26rpx 22rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 52rpx rgba(32, 48, 51, 0.075);
}

.info-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 20rpx;
}

.info-icon.mint {
  background: #e8f5f1;
}

.info-icon.deep {
  background: #e6efed;
}

.info-title {
  margin-top: 16rpx;
  color: #8a969b;
  font-size: 22rpx;
  font-weight: 700;
}

.info-value {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 8rpx;
  color: #253236;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.25;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.contact-card {
  overflow: hidden;
  margin-top: 34rpx;
  border-radius: 28rpx;
  background: rgba(232, 245, 241, 0.9);
  box-shadow: 0 18rpx 48rpx rgba(15, 107, 93, 0.08);
  animation: sectionEnter 430ms 180ms ease both;
  transition: transform 160ms ease, opacity 160ms ease;
}

.contact-card:active {
  opacity: 0.9;
  transform: scale(0.985);
}

.contact-card-content {
  min-height: 142rpx;
  padding: 24rpx 26rpx;
}

.contact-icon {
  flex: 0 0 auto;
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 107, 93, 0.1);
}

.contact-main {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}

.contact-title {
  color: #173436;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.2;
}

.contact-copy {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 8rpx;
  color: #6c7c80;
  font-size: 22rpx;
  line-height: 1.3;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.contact-button {
  flex: 0 0 auto;
  min-width: 104rpx;
  height: 58rpx;
  margin-left: 18rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 58rpx;
  text-align: center;
  background: #0a9875;
  box-shadow: 0 12rpx 26rpx rgba(10, 152, 117, 0.18);
}

.tool-section {
  margin-top: 40rpx;
  animation: sectionEnter 430ms 240ms ease both;
}

.section-title {
  color: #263238;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.2;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
  margin-top: 22rpx;
}

.tool-item {
  display: flex;
  min-height: 158rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 52rpx rgba(32, 48, 51, 0.07);
  transition: transform 160ms ease, opacity 160ms ease;
}

.tool-item:active {
  opacity: 0.88;
  transform: scale(0.98);
}

.tool-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: #e8f5f1;
}

.tool-icon.danger {
  background: #fff0ee;
}

.tool-label {
  margin-top: 16rpx;
  color: #253236;
  font-size: 25rpx;
  font-weight: 800;
}

.tool-item.danger .tool-label {
  color: #d93026;
}

.bottom-nav {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  box-sizing: border-box;
  height: calc(112rpx + constant(safe-area-inset-bottom));
  height: calc(112rpx + env(safe-area-inset-bottom));
  padding: 8rpx 0 calc(8rpx + constant(safe-area-inset-bottom));
  padding: 8rpx 0 calc(8rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(217, 226, 231, 0.78);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -12rpx 34rpx rgba(44, 58, 73, 0.05);
}

.nav-item {
  justify-content: center;
  flex-direction: column;
  gap: 4rpx;
  color: #8d979c;
  font-size: 22rpx;
  font-weight: 600;
}

.nav-item.active {
  color: #0a9875;
}

.nav-mark {
  position: relative;
  width: 44rpx;
  height: 44rpx;
}

.nav-home::before {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 7rpx 7rpx 9rpx 9rpx;
  background: #9ba5aa;
  content: "";
}

.nav-home::after {
  position: absolute;
  top: 2rpx;
  left: 9rpx;
  width: 26rpx;
  height: 26rpx;
  border-radius: 5rpx;
  background: #9ba5aa;
  content: "";
  transform: rotate(45deg);
}

.nav-item.active .nav-home::before,
.nav-item.active .nav-home::after {
  background: #0a9875;
}

.nav-item.active .nav-home::before {
  z-index: 1;
}

.nav-item.active .nav-home::after {
  z-index: 0;
}

.nav-user::before {
  position: absolute;
  top: 5rpx;
  left: 15rpx;
  width: 14rpx;
  height: 14rpx;
  border: 4rpx solid #9ba5aa;
  border-radius: 999rpx;
  content: "";
}

.nav-user::after {
  position: absolute;
  right: 8rpx;
  bottom: 5rpx;
  left: 8rpx;
  height: 17rpx;
  border: 4rpx solid #9ba5aa;
  border-radius: 999rpx 999rpx 6rpx 6rpx;
  content: "";
}

.nav-item.active .nav-user::before,
.nav-item.active .nav-user::after {
  border-color: #0a9875;
}

@keyframes sectionEnter {
  from {
    opacity: 0;
    transform: translateY(22rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes avatarFloat {
  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-8rpx);
  }
}

@keyframes bgDrift {
  from {
    transform: scale(1.04) translate3d(0, 0, 0);
  }

  to {
    transform: scale(1.06) translate3d(-12rpx, -8rpx, 0);
  }
}

@keyframes visualFloat {
  from {
    transform: scale(1) translate3d(0, 0, 0);
  }

  to {
    transform: scale(1.02) translate3d(-10rpx, -6rpx, 0);
  }
}
