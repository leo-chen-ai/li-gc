.onboarding-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 92rpx 30rpx calc(46rpx + constant(safe-area-inset-bottom));
  padding: 92rpx 30rpx calc(46rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 16% 0%, rgba(214, 244, 238, 0.94) 0, rgba(214, 244, 238, 0) 236rpx),
    linear-gradient(180deg, #f5f8f8 0%, #eef4f5 100%);
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 20rpx;
  color: #102427;
  font-size: 48rpx;
  font-weight: 400;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 12rpx 28rpx rgba(42, 59, 78, 0.06);
}

.topbar-title {
  color: #263438;
  font-size: 28rpx;
  font-weight: 800;
}

.topbar-spacer {
  width: 58rpx;
}

.intro-panel {
  position: relative;
  overflow: hidden;
  margin-top: 28rpx;
  padding: 34rpx 30rpx 36rpx;
  border-radius: 24rpx;
  background: linear-gradient(115deg, #ffffff 0%, #eef8f5 62%, #fff7ec 100%);
  box-shadow: 0 18rpx 46rpx rgba(42, 59, 78, 0.07);
}

.intro-bg {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.58;
}

.intro-panel::after {
  position: absolute;
  right: -42rpx;
  bottom: -62rpx;
  width: 210rpx;
  height: 210rpx;
  border-radius: 999rpx;
  background: rgba(10, 152, 117, 0.08);
  content: "";
}

.intro-kicker {
  position: relative;
  z-index: 1;
  color: #0a9875;
  font-size: 22rpx;
  font-weight: 800;
}

.intro-title {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  color: #17282b;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.12;
}

.intro-copy {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  max-width: 560rpx;
  color: #627277;
  font-size: 24rpx;
  line-height: 1.5;
}

.onboarding-form {
  margin-top: 22rpx;
}

.form-section {
  padding: 28rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 42rpx rgba(42, 59, 78, 0.055);
}

.form-section + .form-section {
  margin-top: 20rpx;
}

.section-title {
  margin-bottom: 20rpx;
  color: #1f2d30;
  font-size: 30rpx;
  font-weight: 800;
}

.field-row {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  margin-top: 18rpx;
}

.field-row .field {
  margin-top: 0;
}

.field {
  min-width: 0;
  margin-top: 18rpx;
}

.field:first-child,
.section-title + .field {
  margin-top: 0;
}

.field.half {
  flex: 1;
}

.project-readonly {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #f3f8f7;
}

.readonly-label {
  color: #7d8b90;
  font-size: 22rpx;
}

.readonly-value {
  margin-top: 8rpx;
  color: #263438;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.4;
}

.field-label {
  margin-bottom: 10rpx;
  color: #4f5d62;
  font-size: 23rpx;
  font-weight: 700;
}

.field-label text {
  color: #d65a44;
}

.field-input,
.select-value,
.field-textarea {
  box-sizing: border-box;
  width: 100%;
  border: 1rpx solid #dbe5e8;
  border-radius: 18rpx;
  color: #223034;
  font-size: 26rpx;
  background: #f8fbfb;
}

.field-input,
.select-value {
  height: 78rpx;
  padding: 0 22rpx;
  line-height: 78rpx;
}

.field-textarea {
  height: 154rpx;
  padding: 20rpx 22rpx;
  line-height: 1.45;
}

.field-textarea.compact {
  height: 126rpx;
}

.price-row {
  display: grid;
  grid-template-columns: 1fr 52rpx;
  align-items: center;
  gap: 12rpx;
}

.price-unit {
  color: #4f5d62;
  font-size: 25rpx;
  text-align: center;
}

.photo-tips {
  margin-top: -4rpx;
  color: #98a5aa;
  font-size: 21rpx;
  line-height: 1.42;
}

.face-upload-card {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 166rpx;
  margin-top: 18rpx;
  padding: 18rpx 22rpx 18rpx 18rpx;
  border: 2rpx dashed rgba(10, 152, 117, 0.34);
  border-radius: 20rpx;
  background: linear-gradient(135deg, #f7fbfa 0%, #eef8f5 100%);
}

.face-upload-card::after {
  flex: none;
  margin-left: 14rpx;
  color: #0a9875;
  font-size: 42rpx;
  line-height: 1;
  content: "›";
}

.face-upload-card:active,
.id-upload-card:active {
  transform: scale(0.992);
}

.face-image {
  flex: none;
  width: 148rpx;
  height: 148rpx;
  border-radius: 18rpx;
  background: #e9f4f1;
}

.face-upload-copy {
  min-width: 0;
  margin-left: 20rpx;
}

.upload-title {
  color: #163337;
  font-size: 27rpx;
  font-weight: 800;
}

.upload-subtitle {
  margin-top: 8rpx;
  color: #738287;
  font-size: 22rpx;
  line-height: 1.35;
}

.id-ocr-title {
  margin-top: 28rpx;
  color: #263438;
  font-size: 26rpx;
  font-weight: 800;
}

.id-upload-card {
  overflow: hidden;
  margin-top: 16rpx;
  border: 2rpx dashed rgba(10, 152, 117, 0.28);
  border-radius: 18rpx;
  background: #ffffff;
  transition: transform 120ms ease;
}

.id-upload-card.back {
  background: #ffffff;
}

.id-image-wrap {
  position: relative;
  overflow: hidden;
  height: 238rpx;
  background: #edf7f4;
}

.id-illustration {
  display: block;
  width: 100%;
  height: 100%;
}

.id-image-wrap::after {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 104rpx;
  background: linear-gradient(180deg, rgba(247, 251, 250, 0) 0%, rgba(247, 251, 250, 0.88) 100%);
  content: "";
}

.id-upload-action {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 1;
  min-width: 218rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid rgba(10, 152, 117, 0.2);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 28rpx rgba(42, 59, 78, 0.12);
}

.id-upload-action .upload-title {
  color: #0a9875;
  font-size: 24rpx;
}

.id-upload-action .upload-subtitle {
  margin-top: 4rpx;
  font-size: 19rpx;
}

.id-upload-footer {
  padding: 18rpx 20rpx 20rpx;
  background: #f8fbfb;
}

.id-upload-title {
  color: #1f2d30;
  font-size: 26rpx;
  font-weight: 800;
}

.id-upload-line {
  margin-top: 16rpx;
  color: #66757b;
  font-size: 23rpx;
  line-height: 1.45;
}

.muted-placeholder {
  color: #a2adb1;
}

.submit-notice {
  margin-top: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  color: #0a745c;
  font-size: 23rpx;
  background: #e9f7f2;
}

.submit-button {
  height: 88rpx;
  margin-top: 22rpx;
  border-radius: 22rpx;
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 88rpx;
  text-align: center;
  background: #0a9875;
  box-shadow: 0 16rpx 34rpx rgba(10, 152, 117, 0.22);
}

.phone-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 40;
  background: rgba(16, 31, 35, 0.42);
}

.phone-modal {
  position: fixed;
  right: 38rpx;
  left: 38rpx;
  top: 20vh;
  z-index: 41;
  box-sizing: border-box;
  overflow: hidden;
  padding: 52rpx 32rpx 32rpx;
  border-radius: 34rpx;
  background: #ffffff;
  box-shadow: 0 30rpx 90rpx rgba(16, 31, 35, 0.24);
  opacity: 0;
  transform: translateY(22rpx);
  transition: opacity 160ms ease, transform 160ms ease;
  pointer-events: none;
}

.phone-modal::after {
  position: absolute;
  top: 20rpx;
  left: 50%;
  width: 76rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(16, 31, 35, 0.12);
  content: "";
  transform: translateX(-50%);
}

.phone-modal.show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.phone-modal-title,
.phone-modal-copy,
.phone-input-wrap,
.phone-match-tip,
.phone-modal-actions {
  position: relative;
  z-index: 1;
}

.phone-modal-title {
  color: #17282b;
  font-size: 34rpx;
  font-weight: 800;
}

.phone-modal-copy {
  margin-top: 12rpx;
  color: #69777d;
  font-size: 24rpx;
  line-height: 1.45;
}

.phone-input-wrap {
  margin-top: 28rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(10, 152, 117, 0.16);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.72);
}

.phone-input {
  height: 82rpx;
  color: #223034;
  font-size: 30rpx;
}

.phone-match-tip {
  margin-top: 16rpx;
  color: #0a9875;
  font-size: 23rpx;
  font-weight: 700;
}

.phone-modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.modal-ghost,
.modal-primary {
  flex: 1;
  height: 78rpx;
  border-radius: 22rpx;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 78rpx;
  text-align: center;
}

.modal-ghost {
  color: #69777d;
  background: #eef3f4;
}

.modal-primary {
  color: #ffffff;
  background: #0a9875;
}
